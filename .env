# =================================
#      CONFIGURAÇÃO DO TELEGRAM
# =================================
# Token do seu bot, obtido com o @BotFather
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# Username do seu bot, também do @BotFather
TELEGRAM_BOT_USERNAME=SEU_USERNAME_DO_BOT

# =================================
#    CONFIGURAÇÃO DO BANCO DE DADOS
# =================================
# URL de conexão que o serviço Java usará para se conectar ao container do DB.
# 'db' é o nome do serviço do PostgreSQL no docker-compose.yml.
DB_URL=jdbc:postgresql://db:5432/financialdb

# Credenciais para o banco de dados. Devem ser as mesmas usadas
# na configuração do serviço 'db' no docker-compose.yml.
DB_USER=admin
DB_PASSWORD=secret

# =================================
#   CONFIGURAÇÃO DOS MICROSSERVIÇOS
# =================================
# URL que o serviço Java usará para se comunicar com o serviço Python.
# 'analysis-service' é o nome do serviço Python no docker-compose.yml.
ANALYSIS_SERVICE_URL=http://analysis-service:5001
